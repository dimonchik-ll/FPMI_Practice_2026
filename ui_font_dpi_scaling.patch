@@ -29,8 +29,19 @@ class UiTheme:
 
 
 class UiFonts:
+    """Load a native UI font instead of Pygame's bundled fallback font."""
+
+    _FAMILIES = ("segoe ui", "arial", "noto sans", "dejavu sans")
+
     def __init__(self) -> None:
-        self.title = pygame.font.Font(None, 32)
-        self.section = pygame.font.Font(None, 24)
-        self.body = pygame.font.Font(None, 22)
-        self.small = pygame.font.Font(None, 18)
+        self.title = self._load(32, bold=True)
+        self.section = self._load(24, bold=True)
+        self.body = self._load(22)
+        self.small = self._load(18)
+
+    @classmethod
+    def _load(cls, size: int, *, bold: bool = False) -> pygame.font.Font:
+        font_path = pygame.font.match_font(cls._FAMILIES, bold=bold)
+        if font_path is None:
+            return pygame.font.Font(None, size)
+        return pygame.font.Font(font_path, size)
