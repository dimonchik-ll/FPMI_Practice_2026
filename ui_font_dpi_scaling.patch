 from __future__ import annotations
 
+import os
+import sys
+
+# Keep the game sharp on Windows displays that use 125%, 150% or 200% scaling.
+# This must be set before pygame initializes the video subsystem.
+# SDL then keeps coordinates in logical DPI-scaled points, so the current
+# UI layout and mouse coordinates remain unchanged.
+if sys.platform == "win32":
+    os.environ.setdefault("SDL_WINDOWS_DPI_SCALING", "1")
+
 import pygame
 
 from core.game_shell import CoreWorld
